{
  "description": "MemPalace Autopilot — auto-capture and context injection",
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "_R=\"${CLAUDE_PLUGIN_ROOT}\"; [ -z \"$_R\" ] && _R=\"/Users/raoof.r12/.claude/plugins/cache/Raoof128/mempalace-autopilot/1.0.0\"; python3 \"$_R/hooks/hook_runner.py\" session-start",
            "timeout": 30
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "_R=\"${CLAUDE_PLUGIN_ROOT}\"; [ -z \"$_R\" ] && _R=\"/Users/raoof.r12/.claude/plugins/cache/Raoof128/mempalace-autopilot/1.0.0\"; python3 \"$_R/hooks/hook_runner.py\" stop",
            "timeout": 30
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "_R=\"${CLAUDE_PLUGIN_ROOT}\"; [ -z \"$_R\" ] && _R=\"/Users/raoof.r12/.claude/plugins/cache/Raoof128/mempalace-autopilot/1.0.0\"; python3 \"$_R/hooks/hook_runner.py\" precompact",
            "timeout": 60
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "_R=\"${CLAUDE_PLUGIN_ROOT}\"; [ -z \"$_R\" ] && _R=\"/Users/raoof.r12/.claude/plugins/cache/Raoof128/mempalace-autopilot/1.0.0\"; python3 \"$_R/hooks/hook_runner.py\" session-end",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
